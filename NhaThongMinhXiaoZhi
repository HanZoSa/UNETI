// Sinric Pro Callbacks
bool onPowerStateDen(const String &id, bool &s) { updateDevice("den", s); return true; }
bool onPowerStateQuat(const String &id, bool &s) { setFanPower(s); return true; }
bool onPowerStateCua(const String &id, bool &s) { updateDevice("cua", s); return true; } 

// Đăng ký công cụ điều khiển với AI Xiaozhi
void registerMcpTools() {
  mcpClient.registerTool(
    "smart_home",
    "Dieu khien den, quat, cua va che do tu dong cua cam bien.", // Cập nhật mô tả cho AI hiểu
    "{\"type\":\"object\",\"properties\":{\"device\":{\"type\":\"string\",\"enum\":[\"den\",\"quat\",\"cua\",\"cam_bien\"]},\"action\":{\"type\":\"string\",\"enum\":[\"on\",\"off\"]}}}", // THÊM "cam_bien" vào danh sách lệnh AI
    [](const String& args) {
      DynamicJsonDocument doc(256);
      deserializeJson(doc, args);
      updateDevice(doc["device"], doc["action"] == "on");
      return WebSocketMCP::ToolResponse("{\"status\":\"success\"}");
    }
  );
}

