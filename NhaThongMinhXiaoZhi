bool currentDoorState = false; 
bool isAutoMode = true; // Trạng thái bật/tắt cảm biến tự động

void setDoor(bool state) {
  currentDoorState = state; 

  if (state) {
    Serial.println("Dang mo cua -> Quay den goc 100 do.");
    servoCua.write(100);  
  } else {
    Serial.println("Dang dong cua -> Quay ve goc 0 do.");
    servoCua.write(0);    
  }
  
  if (Blynk.connected()) Blynk.virtualWrite(V3, state ? 1 : 0);
  SinricProSwitch &myDoor = SinricPro[ID_CUA];
  myDoor.sendPowerStateEvent(state);
}

void setFanPower(bool state) {
  digitalWrite(PIN_QUAT, state ? HIGH : LOW);
  Serial.print("Quat: "); Serial.println(state ? "BAT" : "TAT");
  if (Blynk.connected()) Blynk.virtualWrite(V2, state ? 1 : 0);
  SinricProSwitch &myFan = SinricPro[ID_QUAT];
  myFan.sendPowerStateEvent(state);
}

// Hàm xử lý bật tắt Chế độ tự động riêng biệt
void setAutoMode(bool state) {
  isAutoMode = state;
  Serial.print("Che do cam bien tu dong: "); 
  Serial.println(isAutoMode ? "BAT" : "TAT");
  if (Blynk.connected()) Blynk.virtualWrite(V4, state ? 1 : 0); // Cập nhật lại nút V4 trên Blynk
}

// --- HÀM CẬP NHẬT TRẠNG THÁI CHUNG CHÍNH ---
void updateDevice(String device, bool state) {
  if (device == "den") {
    digitalWrite(PIN_DEN, state ? HIGH : LOW);
    Serial.print("Den: "); Serial.println(state ? "BAT" : "TAT");
    if (Blynk.connected()) Blynk.virtualWrite(V1, state ? 1 : 0);
    SinricProSwitch &myLight = SinricPro[ID_DEN];
    myLight.sendPowerStateEvent(state);
  } else if (device == "quat") {
    setFanPower(state);
  } else if (device == "cua") { 
    // Khi cố tình ra lệnh Ép đóng/mở cửa bằng tay -> Tạm tắt tự động để tránh xung đột
    setAutoMode(false); 
    setDoor(state);
  } else if (device == "cam_bien") { // TÍCH HỢP MỚI: Điều khiển chế độ tự động
    setAutoMode(state);
  }
}

